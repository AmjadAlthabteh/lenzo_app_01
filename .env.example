# Rename this file to .env.local and fill in your values

# Required: OpenAI API key for AI summarization and content moderation
OPENAI_API_KEY=

# Database connection string (SQLite for local development)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Encryption Secret (for 2FA secrets, backup codes, sensitive data)
# Generate a random secret: openssl rand -base64 32
ENCRYPTION_SECRET=your-encryption-secret-here

# Optional: GitHub OAuth credentials for authentication
GITHUB_ID=
GITHUB_SECRET=

# Base URL for your application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: AWS S3 credentials for media storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
