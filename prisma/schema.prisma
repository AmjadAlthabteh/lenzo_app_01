generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  password          String?             // Hashed password
  image             String?
  role              String              @default("USER") // USER, MODERATOR, ADMIN, SUPER_ADMIN

  // 2FA fields
  twoFactorEnabled  Boolean             @default(false)
  twoFactorSecret   String?             // TOTP secret (encrypted)
  backupCodes       String?             // Encrypted JSON array of backup codes

  // Security
  emailVerified     DateTime?
  locked            Boolean             @default(false)
  failedLoginAttempts Int              @default(0)
  lastFailedLogin   DateTime?

  // Relations
  accounts          Account[]
  sessions          Session[]
  posts             Post[]
  permissions       UserPermission[]
  collaborations    Collaboration[]
  activities        Activity[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique       // e.g., "post:create", "user:delete", "admin:access"
  description String?
  users       UserPermission[]
  createdAt   DateTime         @default(now())
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now())

  @@id([userId, permissionId])
}

model Collaboration {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  type        String   // "edit", "view", "comment"
  isActive    Boolean  @default(true)
  cursorPos   String?  // JSON: {x, y, selection}
  lastSeenAt  DateTime @default(now())

  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([postId, userId])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  action      String   // "login", "logout", "post.create", "post.edit", etc.
  entityType  String?  // "post", "user", etc.
  entityId    String?
  metadata    String?  // Encrypted JSON with additional details
  ipAddress   String?
  userAgent   String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @map("refreshToken")
  access_token       String? @map("accessToken")
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id              String          @id @default(cuid())
  title           String
  story           String
  summary         String?
  mediaUrl        String?
  mediaType       String?         // image, video, etc.
  aiDescription   String?         // AI-generated image description
  aiObjects       String?         // Detected objects (JSON array)
  aiColors        String?         // Dominant colors (JSON array)
  aiLabels        String?         // AI-detected labels/categories (JSON array)
  aiConfidence    Float?          // AI analysis confidence score

  // Collaboration & encryption
  encryptedData   String?         // Encrypted sensitive content
  isPublic        Boolean         @default(true)
  allowCollaboration Boolean      @default(false)

  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tags            PostTag[]
  collaborations  Collaboration[]
}

model Tag {
  id    String   @id @default(cuid())
  name  String   @unique
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

